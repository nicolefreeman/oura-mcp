{
  "name": "oura-mcp",
  "version": "1.0.0",
  "description": "MCP server for Oura Ring API v2 — sleep, readiness, HRV, stress, cycle, and coaching",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "clean": "rm -rf build",
    "test": "TZ=UTC node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "TZ=UTC node --experimental-vm-modules node_modules/.bin/jest --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "dotenv": "^16.0.0",
    "node-fetch": "^3.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
